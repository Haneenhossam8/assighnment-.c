#include <stdio.h>

int main()
{
int x=10,y=20,z=30;
int *p=&x;
int *q=&y;
int *r=&z;
int *t;
printf("Before Swapping:\n");
printf("x=%d y=%d z=%d\n",x,y,z);
printf("*p=%d *q=%d *r=%d\n",*p,*q,*r);
t=p;
p=q;
q=r;
r=t;
printf("After Swapping:\n");
printf("x=%d y=%d z=%d\n",x,y,z);
printf("*p=%d *q=%d *r=%d\n",*p,*q,*r);
return 0;
}
