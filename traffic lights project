#define F_CPU 8000000UL
#include <util/delay.h>
#include "DIO.h"
u8 numbers[10]={0x3F,0x06,0x5B,0x4F,0x66,0x6D,0x7D,0x07,0x7F,0x6F};

void DisplayNumber(u8 num)
{
	DIO_SetPortValue(PORTC,numbers[num/10]);
	DIO_SetPortValue(PORTD,numbers[num%10]);
}

int main(void)
{
	DIO_SetPortDirection(PORTA,0xFF);
	DIO_SetPortDirection(PORTC,0xFF);
	DIO_SetPortDirection(PORTD,0xFF);

	while(1)
	{
		DIO_SetPortValue(PORTA,0x01);

		for(u8 i=10;i>0;i--)
		{
			DisplayNumber(i);
			_delay_ms(1000);
		}

		DIO_SetPortValue(PORTA,0x02);

		for(u8 i=3;i>0;i--)
		{
			DisplayNumber(i);
			_delay_ms(1000);
		}

		DIO_SetPortValue(PORTA,0x04);

		for(u8 i=10;i>0;i--)
		{
			DisplayNumber(i);
			_delay_ms(1000);
		}
	}
}
